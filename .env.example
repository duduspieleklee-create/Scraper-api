# === Datenbank ===
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# === Fuer lokale Entwicklung mit Docker Compose ===
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/kleinanzeigen

# === Passwort fuer lokale Docker DB ===
POSTGRES_PASSWORD=your_password_here

# === JWT Auth (PFLICHT in Produktion!) ===
# Generieren mit: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# === Scraper-Einstellungen ===
REQUEST_DELAY_MIN=1.5
REQUEST_DELAY_MAX=4.0
REQUEST_TIMEOUT=30
